# Supabase — local dev uses the values printed by `pnpm supabase start`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — scripts/ only, NEVER import in client or server components
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Feature flags
ENABLE_LLM_CATEGORIZATION=false   # opt-in; costs $ per transaction

# Security
CRON_SECRET=a-random-secret        # protects /api/sync endpoint
INVITE_SECRET=another-random-secret # signs household invite tokens
