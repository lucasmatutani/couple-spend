{
  "name": "splitwise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "gen:types": "supabase gen types typescript --local --workdir infra/supabase > packages/shared/src/database.types.ts",
    "supabase": "supabase --workdir infra/supabase",
    "supabase:start": "supabase start --workdir infra/supabase",
    "supabase:stop": "supabase stop --workdir infra/supabase",
    "supabase:reset": "supabase db reset --workdir infra/supabase",
    "supabase:status": "supabase status --workdir infra/supabase"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
