# Supabase — use `pnpm supabase status --output env` and copy ANON_KEY (eyJ...) and SERVICE_ROLE_KEY (eyJ...).
# Do NOT use the PUBLISHABLE_KEY (sb_publishable_*) — PostgREST requires the JWT-format anon key for auth.uid() to work.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-jwt-anon-key

# Server-only — scripts/ only, NEVER import in client or server components
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-jwt-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...     # from infra/stripe/setup-products.ts
STRIPE_FAMILY_PRICE_ID=price_...  # from infra/stripe/setup-products.ts

# Anthropic (PDF extraction via Claude Vision)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (free alternative for PDF extraction)
# Get key at: https://aistudio.google.com → Get API key (no credit card needed)
GOOGLE_AI_API_KEY=AIza...
# PDF_EXTRACTOR=gemini      # uncomment to use Gemini instead of Claude (default: claude)
# GEMINI_MODEL=gemini-1.5-flash  # default; use gemini-2.0-flash if your project has quota

# Open Finance (Pluggy)
PLUGGY_CLIENT_ID=your-pluggy-client-id
PLUGGY_CLIENT_SECRET=your-pluggy-client-secret

# Security
CRON_SECRET=a-random-secret        # protects /api/sync endpoint
INVITE_SECRET=another-random-secret # signs household invite tokens

# Email (Resend — https://resend.com, free tier: 100 emails/day)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
